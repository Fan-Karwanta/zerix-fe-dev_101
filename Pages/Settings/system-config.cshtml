        </div>
        <div class="sc-mobile-save-wrapper">
            <button class="sc-save-btn sc-save-btn-mobile" onclick="saveSystemConfig()">Save</button>
        </div>
    </div>
</div>

<style>
    /* ==================== SYSTEM CONFIGURATION - DEDICATED STYLES ==================== */

    .sc-content-wrapper {
        max-width: 450px;
    }

    .sc-mobile-title {
        font-family: 'Microsoft Sans Serif', sans-serif;
        font-size: 20px;
        font-weight: 400;
        color: #495057;
        margin-bottom: 24px;
        margin-top: 8px;
    }

    .sc-label {
        font-family: 'Microsoft Sans Serif', sans-serif;
        font-size: 14px;
        font-weight: 400;
        color: #495057;
        margin-bottom: 12px;
    }

    /* Upload Area */
    .sc-upload-area {
        border: 1px dashed #C4C4C4;
        border-radius: 8px;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        position: relative;
        background-color: #FFFFFF;
        transition: border-color 0.2s ease, background-color 0.2s ease;
        max-width: 350px;
        min-height: 200px;
    }

    .sc-upload-area:hover {
        border-color: #FF5400;
        background-color: #FFF9F5;
    }

    .sc-upload-area.sc-dragover {
        border-color: #FF5400;
        background-color: #FFF3EB;
    }

    .sc-upload-area-mobile {
        max-width: 100%;
    }

    .sc-upload-icon {
        margin-bottom: 12px;
    }

    .sc-upload-text {
        font-family: 'Microsoft Sans Serif', sans-serif;
        font-size: 14px;
        font-weight: 400;
        color: #878A99;
        margin-bottom: 4px;
    }

    .sc-upload-subtext {
        font-family: 'Microsoft Sans Serif', sans-serif;
        font-size: 12px;
        font-weight: 400;
        color: #C4C4C4;
    }

    .sc-file-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    /* Preview */
    .sc-preview-container {
        position: relative;
        max-width: 350px;
        margin-top: 12px;
        border: 1px solid #E6E6E6;
        border-radius: 8px;
        padding: 12px;
        background-color: #FFFFFF;
    }

    .sc-preview-img {
        max-width: 100%;
        max-height: 200px;
        display: block;
        margin: 0 auto;
        border-radius: 4px;
    }

    .sc-remove-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        background: #FF5400;
        color: #FFFFFF;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        font-size: 14px;
        line-height: 24px;
        text-align: center;
        cursor: pointer;
        padding: 0;
    }

    .sc-remove-btn:hover {
        background: #e04900;
    }

    /* Save Button */
    .sc-recommended-size {
        font-family: 'Microsoft Sans Serif', sans-serif;
        font-size: 12px;
        font-style: italic;
        font-weight: 400;
        color: #C4C4C4;
        margin-top: 8px;
        text-align: center;
    }

    .sc-save-wrapper {
        margin-top: 40px;
        display: flex;
        justify-content: flex-start;
        max-width: 350px;
    }

    .sc-save-btn {
        background-color: #FF5400;
        border: none;
        color: #FFFFFF;
        padding: 12px 48px;
        font-family: 'Microsoft Sans Serif', sans-serif;
        font-size: 16px;
        font-weight: 400;
        border-radius: 4px;
        cursor: pointer;
        min-width: 160px;
        text-align: center;
    }

    .sc-save-btn:hover {
        background-color: #e04900;
    }

    /* Mobile Save */
    .sc-mobile-save-wrapper {
        margin-top: 32px;
        margin-bottom: 32px;
    }

    .sc-save-btn-mobile {
        width: 100%;
        padding: 14px 24px;
        font-size: 16px;
        border-radius: 4px;
    }

    /* ==================== RESPONSIVE ==================== */

    @@media (max-width: 991px) {
        .sc-preview-container {
            max-width: 100%;
        }
    }
</style>

<script>
    // Desktop drag & drop and file input
    (function () {
        var desktopDropZone = document.getElementById('scDesktopDropZone');
        var desktopFileInput = document.getElementById('scDesktopFileInput');
        var desktopPreview = document.getElementById('scDesktopPreview');
        var desktopPreviewImg = document.getElementById('scDesktopPreviewImg');

        if (desktopDropZone) {
            desktopDropZone.addEventListener('dragover', function (e) {
                e.preventDefault();
                desktopDropZone.classList.add('sc-dragover');
            });
            desktopDropZone.addEventListener('dragleave', function () {
                desktopDropZone.classList.remove('sc-dragover');
            });
            desktopDropZone.addEventListener('drop', function (e) {
                e.preventDefault();
                desktopDropZone.classList.remove('sc-dragover');
                var files = e.dataTransfer.files;
                if (files.length > 0) {
                    handleDesktopFile(files[0]);
                }
            });
        }

        if (desktopFileInput) {
            desktopFileInput.addEventListener('change', function () {
                if (this.files.length > 0) {
                    handleDesktopFile(this.files[0]);
                }
            });
        }

        window.handleDesktopFile = function (file) {
            var validTypes = ['image/jpeg', 'image/jpg', 'image/png'];
            if (validTypes.indexOf(file.type) === -1) {
                alert('Please upload a .jpeg, .jpg, or .png file.');
                return;
            }
            var reader = new FileReader();
            reader.onload = function (e) {
                desktopPreviewImg.src = e.target.result;
                desktopPreview.style.display = 'block';
                desktopDropZone.style.display = 'none';
            };
            reader.readAsDataURL(file);
        };

        window.removeDesktopFile = function () {
            desktopPreviewImg.src = '';
            desktopPreview.style.display = 'none';
            desktopDropZone.style.display = 'flex';
            desktopFileInput.value = '';
        };
    })();

    // Mobile drag & drop and file input
    (function () {
        var mobileDropZone = document.getElementById('scMobileDropZone');
        var mobileFileInput = document.getElementById('scMobileFileInput');
        var mobilePreview = document.getElementById('scMobilePreview');
        var mobilePreviewImg = document.getElementById('scMobilePreviewImg');

        if (mobileDropZone) {
            mobileDropZone.addEventListener('dragover', function (e) {
                e.preventDefault();
                mobileDropZone.classList.add('sc-dragover');
            });
            mobileDropZone.addEventListener('dragleave', function () {
                mobileDropZone.classList.remove('sc-dragover');
            });
            mobileDropZone.addEventListener('drop', function (e) {
                e.preventDefault();
                mobileDropZone.classList.remove('sc-dragover');
                var files = e.dataTransfer.files;
                if (files.length > 0) {
                    handleMobileFile(files[0]);
                }
            });
        }

        if (mobileFileInput) {
            mobileFileInput.addEventListener('change', function () {
                if (this.files.length > 0) {
                    handleMobileFile(this.files[0]);
                }
            });
        }

        window.handleMobileFile = function (file) {
            var validTypes = ['image/jpeg', 'image/jpg', 'image/png'];
            if (validTypes.indexOf(file.type) === -1) {
                alert('Please upload a .jpeg, .jpg, or .png file.');
                return;
            }
            var reader = new FileReader();
            reader.onload = function (e) {
                mobilePreviewImg.src = e.target.result;
                mobilePreview.style.display = 'block';
                mobileDropZone.style.display = 'none';
            };
            reader.readAsDataURL(file);
        };

        window.removeMobileFile = function () {
            mobilePreviewImg.src = '';
            mobilePreview.style.display = 'none';
            mobileDropZone.style.display = 'flex';
            mobileFileInput.value = '';
        };
    })();

    function saveSystemConfig() {
        alert('System configuration saved successfully!');
    }
</script>
