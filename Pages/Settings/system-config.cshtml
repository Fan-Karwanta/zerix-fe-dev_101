<!-- System Configuration Content -->
<div class="container my-4 px-4" id="systemConfigSection">
    <!-- Desktop View -->
    <div class="d-none d-lg-block">
        <div class="sc-content-wrapper">
            <div class="sc-label">Logo</div>
            <div class="sc-upload-area" id="scDesktopDropZone">
                <div class="sc-upload-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 16V8M12 8L9 11M12 8L15 11" stroke="#C4C4C4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M4 12C4 7.58172 7.58172 4 12 4C16.4183 4 20 7.58172 20 12C20 16.4183 16.4183 20 12 20C7.58172 20 4 16.4183 4 12Z" stroke="#C4C4C4" stroke-width="1.5"/>
                    </svg>
                </div>
                <div class="sc-upload-text">Drag and Drop File</div>
                <div class="sc-upload-subtext">( .jpeg, .jpg, or .png )</div>
                <div class="sc-recommended-size">Recommended Size: 190 X 54px.</div>
                <input type="file" id="scDesktopFileInput" accept=".jpeg,.jpg,.png" class="sc-file-input" />
            </div>
            <div class="sc-preview-container" id="scDesktopPreview" style="display: none;">
                <img id="scDesktopPreviewImg" src="" alt="Logo Preview" class="sc-preview-img" />
                <button type="button" class="sc-remove-btn" onclick="removeDesktopFile()">&times;</button>
            </div>
            <div class="sc-save-wrapper">
                <button class="sc-save-btn" onclick="saveSystemConfig()">Save</button>
            </div>
        </div>
    </div>

    <!-- Mobile View -->
    <div class="d-block d-lg-none">
        <div class="sc-mobile-title">SYSTEM CONFIGURATION</div>
        <div class="sc-label">Logo</div>
        <div class="sc-upload-area sc-upload-area-mobile" id="scMobileDropZone">
            <div class="sc-upload-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 16V8M12 8L9 11M12 8L15 11" stroke="#C4C4C4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M4 12C4 7.58172 7.58172 4 12 4C16.4183 4 20 7.58172 20 12C20 16.4183 16.4183 20 12 20C7.58172 20 4 16.4183 4 12Z" stroke="#C4C4C4" stroke-width="1.5"/>
                </svg>
