<div class="container px-4 my-3 pt-md-3 pt-3">
    <div class="row">
        <div class="col-12">
            <!-- Desktop Header -->
            <div class="cf-desktop-header">
                <a href="/forms" class="cf-back-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Go Back</span>
                </a>
                <h2 class="cf-page-title">Form Questions</h2>
            </div>

            <!-- Mobile Header -->
            <div class="cf-mobile-header">
                <div class="cf-mobile-header-inner">
                    <a href="/forms" class="cf-mobile-back-link">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                    <h2 class="cf-mobile-page-title">Form Questions</h2>
                </div>
            </div>

            <!-- Tabs -->
            <div class="cf-tabs">
                <button class="cf-tab active" data-tab="questions">Questions</button>
                <span class="cf-tab-divider"></span>
                <button class="cf-tab" data-tab="settings">Settings</button>
            </div>

            <!-- ==================== QUESTIONS TAB ==================== -->
            <div class="cf-tab-content active" id="tab-questions">
                <div class="cf-form-container">
                    <!-- Form Name -->
                    <div class="cf-field-group">
                        <label class="cf-field-label">Form Name</label>
                        <input type="text" class="cf-input-text" placeholder="Enter Name" id="formName">
                    </div>

                    <!-- Description -->
                    <div class="cf-field-group">
                        <label class="cf-field-label">Description <span class="cf-label-optional">(optional)</span></label>
                        <textarea class="cf-textarea" rows="4" placeholder="Write some instructions about the upcoming appointment or refund policy" id="formDescription"></textarea>
                    </div>

                    <!-- Question 1 - Textbox -->
                    <div class="cf-question-container" data-question-index="1">
                        <div class="cf-question-header">
                            <div class="cf-question-left">
                                <label class="cf-question-label">Question 1</label>
                                <button class="cf-delete-btn">Delete</button>
                            </div>
                            <div class="cf-question-right">
                                <div class="cf-type-dropdown">
                                    <button type="button" class="cf-type-dropdown-toggle">
                                        <span class="cf-type-icon">&#9776;</span>
                                        <span class="cf-type-text">Textbox</span>
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="cf-type-arrow">
                                            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="cf-type-dropdown-menu">
                                        <div class="cf-type-dropdown-item" data-value="multiple" data-icon="&#9673;">
                                            <span class="cf-type-item-icon">&#9673;</span>
                                            <span>Multiple Choice</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="dropdown" data-icon="&#9660;">
                                            <span class="cf-type-item-icon">&#9660;</span>
                                            <span>Dropdown List</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="textbox" data-icon="&#9776;">
                                            <span class="cf-type-item-icon">&#9776;</span>
                                            <span>Textbox</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="checkboxes" data-icon="&#9745;">
                                            <span class="cf-type-item-icon">&#9745;</span>
                                            <span>Checkboxes</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="number" data-icon="123">
                                            <span class="cf-type-item-icon">123</span>
                                            <span>Number</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="text" class="cf-question-input" placeholder="ex. Write other concerns.">
                        <div class="cf-required-row">
                            <div class="cf-check-group">
                                <input type="checkbox" class="cf-checkbox" id="cf-required-1">
                                <label class="cf-check-label" for="cf-required-1">Required</label>
                            </div>
                        </div>
                    </div>

                    <!-- Question 2 - Multiple Choice -->
                    <div class="cf-question-container" data-question-index="2">
                        <div class="cf-question-header">
                            <div class="cf-question-left">
                                <label class="cf-question-label">Question 2</label>
                                <button class="cf-delete-btn">Delete</button>
                            </div>
                            <div class="cf-question-right">
                                <div class="cf-type-dropdown">
                                    <button type="button" class="cf-type-dropdown-toggle">
                                        <span class="cf-type-icon">&#9673;</span>
                                        <span class="cf-type-text">Multiple Choice</span>
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="cf-type-arrow">
                                            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="cf-type-dropdown-menu">
                                        <div class="cf-type-dropdown-item" data-value="multiple" data-icon="&#9673;">
                                            <span class="cf-type-item-icon">&#9673;</span>
                                            <span>Multiple Choice</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="dropdown" data-icon="&#9660;">
                                            <span class="cf-type-item-icon">&#9660;</span>
                                            <span>Dropdown List</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="textbox" data-icon="&#9776;">
                                            <span class="cf-type-item-icon">&#9776;</span>
                                            <span>Textbox</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="checkboxes" data-icon="&#9745;">
                                            <span class="cf-type-item-icon">&#9745;</span>
                                            <span>Checkboxes</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="number" data-icon="123">
                                            <span class="cf-type-item-icon">123</span>
                                            <span>Number</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="text" class="cf-question-input" placeholder="ex. Do you reside in Metro Manila?">
                        <div class="cf-options-container">
                            <div class="cf-option-row" data-option-index="1">
                                <input type="text" class="cf-option-input" placeholder="1. Enter Option Here">
                                <button type="button" class="cf-remove-option-btn" title="Remove option">&times;</button>
                            </div>
                            <button type="button" class="cf-add-option-btn">+ Add Option</button>
                        </div>
                        <div class="cf-required-row">
                            <div class="cf-check-group">
                                <input type="checkbox" class="cf-checkbox" id="cf-required-2">
                                <label class="cf-check-label" for="cf-required-2">Required</label>
                            </div>
                        </div>
                    </div>

                    <!-- Question 3 - Checkboxes -->
                    <div class="cf-question-container" data-question-index="3">
                        <div class="cf-question-header">
                            <div class="cf-question-left">
                                <label class="cf-question-label">Question 3</label>
                                <button class="cf-delete-btn">Delete</button>
                            </div>
                            <div class="cf-question-right">
                                <div class="cf-type-dropdown">
                                    <button type="button" class="cf-type-dropdown-toggle">
                                        <span class="cf-type-icon">&#9745;</span>
                                        <span class="cf-type-text">Checkboxes</span>
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="cf-type-arrow">
                                            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="cf-type-dropdown-menu">
                                        <div class="cf-type-dropdown-item" data-value="multiple" data-icon="&#9673;">
                                            <span class="cf-type-item-icon">&#9673;</span>
                                            <span>Multiple Choice</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="dropdown" data-icon="&#9660;">
                                            <span class="cf-type-item-icon">&#9660;</span>
                                            <span>Dropdown List</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="textbox" data-icon="&#9776;">
                                            <span class="cf-type-item-icon">&#9776;</span>
                                            <span>Textbox</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="checkboxes" data-icon="&#9745;">
                                            <span class="cf-type-item-icon">&#9745;</span>
                                            <span>Checkboxes</span>
                                        </div>
                                        <div class="cf-type-dropdown-item" data-value="number" data-icon="123">
                                            <span class="cf-type-item-icon">123</span>
                                            <span>Number</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="text" class="cf-question-input" placeholder="ex. Do you have any allergies?">
                        <div class="cf-options-container">
                            <div class="cf-option-row" data-option-index="1">
                                <input type="text" class="cf-option-input" placeholder="1. Enter Option Here" value="Nuts">
                                <button type="button" class="cf-remove-option-btn" title="Remove option">&times;</button>
                            </div>
                            <div class="cf-option-row" data-option-index="2">
                                <input type="text" class="cf-option-input" placeholder="2. Enter Option Here" value="Dairy">
                                <button type="button" class="cf-remove-option-btn" title="Remove option">&times;</button>
                            </div>
                            <div class="cf-option-row" data-option-index="3">
                                <input type="text" class="cf-option-input" placeholder="3. Enter Option Here" value="None">
                                <button type="button" class="cf-remove-option-btn" title="Remove option">&times;</button>
                            </div>
                            <button type="button" class="cf-add-option-btn">+ Add Option</button>
                        </div>
                        <div class="cf-required-row">
                            <div class="cf-check-group">
                                <input type="checkbox" class="cf-checkbox" id="cf-required-3">
                                <label class="cf-check-label" for="cf-required-3">Required</label>
                            </div>
                        </div>
                    </div>

                    <!-- Add Question Button -->
                    <div class="cf-add-question-wrapper">
                        <button class="cf-add-question-btn">+ Add Question</button>
                    </div>

                    <!-- Desktop Action Buttons -->
                    <div class="cf-action-buttons cf-action-buttons-desktop">
                        <button class="cf-save-link-btn">Save</button>
                        <button class="cf-publish-btn">Publish</button>
                    </div>
                </div>

                <!-- Mobile Action Buttons -->
                <div class="cf-mobile-actions">
                    <button class="cf-publish-btn cf-publish-btn-mobile">Publish</button>
                    <button class="cf-save-link-btn cf-save-link-btn-mobile">Save</button>
                </div>
            </div>

            <!-- ==================== SETTINGS TAB ==================== -->
            <div class="cf-tab-content" id="tab-settings">
                <div class="cf-settings-container">
                    <!-- Accept Responses -->
                    <div class="cf-setting-row">
                        <span class="cf-setting-label">Accept responses</span>
                        <label class="cf-toggle-switch">
                            <input type="checkbox" id="acceptResponses">
                            <span class="cf-toggle-slider"></span>
                        </label>
                    </div>

                    <!-- Set close date & time -->
                    <div class="cf-setting-row">
                        <span class="cf-setting-label">Set close date & time</span>
                        <label class="cf-toggle-switch">
                            <input type="checkbox" id="setCloseDate">
                            <span class="cf-toggle-slider"></span>
                        </label>
                    </div>
                    <div class="cf-setting-detail" id="closeDateDetail" style="display: none;">
                        <div class="cf-datetime-row">
                            <svg class="cf-calendar-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
