        .cf-date-input {
            flex: 1;
            width: auto;
            min-width: 0;
        }

        .cf-time-input {
            width: 45px;
            padding: 8px 6px;
        }

        .cf-ampm-select {
            padding: 8px 4px;
        }

        .cf-field-group {
            margin-bottom: 40px;
        }

        .cf-question-header {
            flex-direction: row;
            align-items: center;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // ==================== TAB SWITCHING ====================
        const tabs = document.querySelectorAll('.cf-tab');
        const tabContents = document.querySelectorAll('.cf-tab-content');

        tabs.forEach(tab => {
            tab.addEventListener('click', function () {
                const targetTab = this.getAttribute('data-tab');

                // Remove active from all tabs and contents
                tabs.forEach(t => t.classList.remove('active'));
                tabContents.forEach(tc => tc.classList.remove('active'));

                // Add active to clicked tab and corresponding content
                this.classList.add('active');
                document.getElementById('tab-' + targetTab).classList.add('active');
            });
        });

        // ==================== QUESTION TYPE DROPDOWNS ====================
        let questionCounter = document.querySelectorAll('.cf-question-container').length;

        const placeholdersByType = {
            'textbox': 'ex. Write other concerns.',
            'multiple': 'ex. Do you reside in Metro Manila?',
            'checkboxes': 'ex. Do you have any allergies?',
            'dropdown': 'ex. Select your preferred time slot',
            'number': 'ex. Enter your age'
        };

        function initializeTypeDropdowns() {
            const dropdowns = document.querySelectorAll('.cf-type-dropdown');

            dropdowns.forEach(dropdown => {
                if (dropdown.dataset.initialized) return;
                dropdown.dataset.initialized = 'true';

                const toggle = dropdown.querySelector('.cf-type-dropdown-toggle');
                const menu = dropdown.querySelector('.cf-type-dropdown-menu');
                const items = dropdown.querySelectorAll('.cf-type-dropdown-item');
                const iconSpan = toggle.querySelector('.cf-type-icon');
                const textSpan = toggle.querySelector('.cf-type-text');

                toggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    document.querySelectorAll('.cf-type-dropdown-menu.show').forEach(otherMenu => {
                        if (otherMenu !== menu) otherMenu.classList.remove('show');
                    });
                    menu.classList.toggle('show');
                });

                items.forEach(item => {
                    item.addEventListener('click', function (e) {
                        e.stopPropagation();
                        const value = this.getAttribute('data-value');
                        const icon = this.getAttribute('data-icon');
                        const textElement = this.querySelector('span:last-child');
                        const text = textElement ? textElement.textContent.trim() : this.textContent.trim();

                        iconSpan.innerHTML = icon;
                        textSpan.textContent = text;

                        const questionContainer = dropdown.closest('.cf-question-container');
                        if (questionContainer) {
                            const questionInput = questionContainer.querySelector('.cf-question-input');
                            if (questionInput && placeholdersByType[value]) {
                                questionInput.placeholder = placeholdersByType[value];
                            }
                            updateQuestionContent(questionContainer, value);
                        }

                        menu.classList.remove('show');
                    });
                });
            });
        }

        function updateQuestionContent(container, type) {
            const existingOptions = container.querySelector('.cf-options-container');
            if (existingOptions) existingOptions.remove();

            if (type === 'multiple' || type === 'checkboxes' || type === 'dropdown') {
                const questionInput = container.querySelector('.cf-question-input');
                const optionsContainer = document.createElement('div');
                optionsContainer.className = 'cf-options-container';
                optionsContainer.innerHTML = `
                    <div class="cf-option-row" data-option-index="1">
                        <input type="text" class="cf-option-input" placeholder="1. Enter Option Here">
                        <button type="button" class="cf-remove-option-btn" title="Remove option">&times;</button>
                    </div>
                    <button type="button" class="cf-add-option-btn">+ Add Option</button>
                `;
                questionInput.insertAdjacentElement('afterend', optionsContainer);
                initializeOptionButtons(optionsContainer);
            }
        }

        function initializeOptionButtons(container) {
            const addBtn = container.querySelector('.cf-add-option-btn');
            if (addBtn && !addBtn.dataset.initialized) {
                addBtn.dataset.initialized = 'true';
                addBtn.addEventListener('click', function () {
                    const optionRows = container.querySelectorAll('.cf-option-row');
                    const newIndex = optionRows.length + 1;
                    const newRow = document.createElement('div');
                    newRow.className = 'cf-option-row';
                    newRow.dataset.optionIndex = newIndex;
                    newRow.innerHTML = `
                        <input type="text" class="cf-option-input" placeholder="${newIndex}. Enter Option Here">
                        <button type="button" class="cf-remove-option-btn" title="Remove option">&times;</button>
                    `;
                    addBtn.insertAdjacentElement('beforebegin', newRow);
                    initializeRemoveButtons(container);
                });
            }
            initializeRemoveButtons(container);
        }

        function initializeRemoveButtons(container) {
            container.querySelectorAll('.cf-remove-option-btn').forEach(btn => {
                if (btn.dataset.initialized) return;
                btn.dataset.initialized = 'true';
                btn.addEventListener('click', function () {
                    const row = this.closest('.cf-option-row');
                    if (row) {
                        row.remove();
                        renumberOptions(container);
                    }
                });
            });
        }

        function renumberOptions(container) {
            const rows = container.querySelectorAll('.cf-option-row');
            rows.forEach((row, index) => {
                const input = row.querySelector('.cf-option-input');
                if (input) {
                    input.placeholder = `${index + 1}. Enter Option Here`;
                    row.dataset.optionIndex = index + 1;
                }
            });
        }

        // ==================== ADD / DELETE QUESTIONS ====================
        function createQuestionHTML(questionNumber) {
            return `
                <div class="cf-question-container" data-question-index="${questionNumber}">
                    <div class="cf-question-header">
                        <div class="cf-question-left">
                            <label class="cf-question-label">Question ${questionNumber}</label>
                            <button class="cf-delete-btn">Delete</button>
                        </div>
                        <div class="cf-question-right">
                            <div class="cf-type-dropdown">
                                <button type="button" class="cf-type-dropdown-toggle">
                                    <span class="cf-type-icon">&#9776;</span>
                                    <span class="cf-type-text">Textbox</span>
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="cf-type-arrow">
                                        <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                                <div class="cf-type-dropdown-menu">
                                    <div class="cf-type-dropdown-item" data-value="multiple" data-icon="&#9673;">
                                        <span class="cf-type-item-icon">&#9673;</span>
                                        <span>Multiple Choice</span>
                                    </div>
                                    <div class="cf-type-dropdown-item" data-value="dropdown" data-icon="&#9660;">
                                        <span class="cf-type-item-icon">&#9660;</span>
                                        <span>Dropdown List</span>
                                    </div>
                                    <div class="cf-type-dropdown-item" data-value="textbox" data-icon="&#9776;">
                                        <span class="cf-type-item-icon">&#9776;</span>
                                        <span>Textbox</span>
                                    </div>
                                    <div class="cf-type-dropdown-item" data-value="checkboxes" data-icon="&#9745;">
                                        <span class="cf-type-item-icon">&#9745;</span>
                                        <span>Checkboxes</span>
                                    </div>
                                    <div class="cf-type-dropdown-item" data-value="number" data-icon="123">
                                        <span class="cf-type-item-icon">123</span>
                                        <span>Number</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <input type="text" class="cf-question-input" placeholder="ex. Write other concerns.">
                    <div class="cf-required-row">
                        <div class="cf-check-group">
                            <input type="checkbox" class="cf-checkbox" id="cf-required-${questionNumber}">
                            <label class="cf-check-label" for="cf-required-${questionNumber}">Required</label>
                        </div>
                    </div>
                </div>
            `;
        }

        const addQuestionBtn = document.querySelector('.cf-add-question-btn');
        if (addQuestionBtn) {
            addQuestionBtn.addEventListener('click', function () {
                questionCounter++;
                const addQuestionWrapper = document.querySelector('.cf-add-question-wrapper');
                addQuestionWrapper.insertAdjacentHTML('beforebegin', createQuestionHTML(questionCounter));
                initializeTypeDropdowns();
                initializeDeleteButtons();
            });
        }

        function initializeDeleteButtons() {
            document.querySelectorAll('.cf-delete-btn').forEach(btn => {
                if (btn.dataset.initialized) return;
                btn.dataset.initialized = 'true';
                btn.addEventListener('click', function () {
                    const questionContainer = this.closest('.cf-question-container');
                    if (questionContainer) {
                        questionContainer.remove();
                        renumberQuestions();
                    }
                });
            });
        }

        function renumberQuestions() {
            const questions = document.querySelectorAll('.cf-question-container');
            questions.forEach((question, index) => {
                const label = question.querySelector('.cf-question-label');
                if (label) label.textContent = `Question ${index + 1}`;
                const checkbox = question.querySelector('.cf-checkbox');
                const checkboxLabel = question.querySelector('.cf-check-label');
                if (checkbox && checkboxLabel) {
                    checkbox.id = `cf-required-${index + 1}`;
                    checkboxLabel.setAttribute('for', `cf-required-${index + 1}`);
                }
                question.dataset.questionIndex = index + 1;
            });
            questionCounter = questions.length;
        }

        // ==================== SETTINGS TOGGLES ====================
        const setCloseDateToggle = document.getElementById('setCloseDate');
        const closeDateDetail = document.getElementById('closeDateDetail');
        if (setCloseDateToggle) {
            setCloseDateToggle.addEventListener('change', function () {
                closeDateDetail.style.display = this.checked ? 'block' : 'none';
            });
        }

        const limitResponsesToggle = document.getElementById('limitResponses');
        const limitResponsesDetail = document.getElementById('limitResponsesDetail');
        if (limitResponsesToggle) {
            limitResponsesToggle.addEventListener('change', function () {
                limitResponsesDetail.style.display = this.checked ? 'block' : 'none';
            });
        }

        // ==================== INITIALIZE ====================
        initializeTypeDropdowns();
        initializeDeleteButtons();

        // Initialize option buttons for existing options containers
        document.querySelectorAll('.cf-options-container').forEach(container => {
            initializeOptionButtons(container);
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function () {
            document.querySelectorAll('.cf-type-dropdown-menu.show').forEach(menu => {
                menu.classList.remove('show');
            });
        });
    });
</script>
