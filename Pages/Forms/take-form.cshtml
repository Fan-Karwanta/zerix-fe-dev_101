<div class="container my-4 px-4">
    <!-- Back link -->
    <div class="mb-3">
        <a href="/forms" class="form-back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                    d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z" />
            </svg>
            Select Form
        </a>
    </div>

    <!-- Form detail -->
    <div class="form-detail-container">
        <div class="form-detail-card">
            <!-- Form header -->
            <div class="form-detail-header">
                <h2 class="form-detail-title">@Model.Form.Title</h2>
                <p class="form-detail-description">@Model.Form.Description</p>
            </div>

            <!-- Form body with questions -->
            <div class="form-detail-body">
                <form id="surveyForm">
                    @foreach (var question in Model.Form.Questions)
                    {
                        <div class="form-field-group">
                            <div class="form-field-label">@question.QuestionText</div>

                            @if (question.QuestionType == "dropdown")
                            {
                                <select class="form-field-select" name="question_@question.Id">
                                    @foreach (var option in question.Options)
                                    {
                                        <option value="@option" selected="@(option == question.DefaultValue)">@option</option>
                                    }
                                </select>
                            }
                            else if (question.QuestionType == "radio")
                            {
                                <div class="form-radio-group">
                                    @foreach (var option in question.Options)
                                    {
                                        <div class="form-radio-item">
                                            <input type="radio" name="question_@question.Id" id="q@(question.Id)_@option.Replace(" ", "_")"
                                                value="@option" @(option == question.DefaultValue ? "checked" : "") />
                                            <label for="q@(question.Id)_@option.Replace(" ", "_")">@option</label>
                                        </div>
                                    }
                                </div>
                            }
                            else if (question.QuestionType == "checkbox")
                            {
                                <div class="form-checkbox-group">
                                    @foreach (var option in question.Options)
                                    {
                                        var isChecked = option == "Health insurance" || option == "Work-from-home option";
                                        <div class="form-checkbox-item">
                                            <input type="checkbox" name="question_@question.Id" id="q@(question.Id)_@option.Replace(" ", "_")"
                                                value="@option" @(isChecked ? "checked" : "") />
                                            <label for="q@(question.Id)_@option.Replace(" ", "_")">@option</label>
                                        </div>
                                    }
                                </div>
                            }
                            else if (question.QuestionType == "text")
                            {
                                <input type="text" class="form-field-input" name="question_@question.Id"
                                    placeholder="Enter here" />
                            }
                        </div>
                    }

                    <div class="mt-4">
                        <button type="button" class="btn-submit-form" id="btnSubmitForm">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade form-success-modal" id="formSuccessModal" tabindex="-1" aria-labelledby="formSuccessModalLabel"
    aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body">
                <div class="form-success-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor"
                        viewBox="0 0 16 16">
                        <path
                            d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
                    </svg>
                </div>
                <div class="form-success-title">Submitted Successfully</div>
                <p class="form-success-message">Your response has been submitted successfully.</p>
                <button type="button" class="btn-close-modal" id="btnCloseSuccessModal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const submitBtn = document.getElementById('btnSubmitForm');
            const closeBtn = document.getElementById('btnCloseSuccessModal');
            const successModal = new bootstrap.Modal(document.getElementById('formSuccessModal'));

            submitBtn.addEventListener('click', function () {
                successModal.show();
            });

            closeBtn.addEventListener('click', function () {
                successModal.hide();
                window.location.href = '/forms';
            });
        });
    </script>
}
